generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Politician {
  id             Int      @id @default(autoincrement())
  name           String
  house          String
  party          String
  district       String?
  age            Int?
  birthDate      String?
  faction        String?
  electionCount  String?
  summaryExcerpt String?
  career         String?
  positions      String?
  policy         String?
  achievements   String?
  evaluations    String?
  rawSummaryMd   String
  sourcesMd      String?
  sourcePath     String   @unique
  isActive       Boolean  @default(true)
  updatedAt      DateTime @updatedAt
  memoryStats    MemoryStats?
  quizAttempts   QuizAttempt[]
}

model MemoryStats {
  politicianId    Int      @id
  politician      Politician @relation(fields: [politicianId], references: [id])
  correctCount    Int      @default(0)
  incorrectCount  Int      @default(0)
  lastAnsweredAt  DateTime?
  memorized       Boolean  @default(false)
}

model QuizAttempt {
  id           Int      @id @default(autoincrement())
  politicianId Int
  politician   Politician @relation(fields: [politicianId], references: [id])
  answeredAt   DateTime @default(now())
  isCorrect    Boolean
}

model Settings {
  id                 Int @id @default(autoincrement())
  memorizedThreshold Int @default(10)
}
